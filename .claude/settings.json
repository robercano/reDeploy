{
  "_README": "Generic harness settings. The hooks call .claude/scripts/gate.sh, which reads commands from .claude/gates.json — so you usually DON'T edit this file per project; you edit gates.json. Enable/disable hooks here as you see fit.",

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/gate.sh lint"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/gate.sh test_affected"
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Read(//**)",
      "Bash(bash .claude/scripts/gate.sh:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git worktree:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm -r:*)",
      "Bash(pnpm --filter:*)",
      "Bash(forge build:*)",
      "Bash(forge test:*)",
      "Bash(forge fmt:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh auth status)"
    ]
  }
}
