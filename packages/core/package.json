{
  "name": "@redeploy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Deployment engine on top of Hardhat Ignition: declarative deployment spec, dependency resolution and ordering, idempotent journal-based resume.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./spec": {
      "types": "./dist/spec/index.d.ts",
      "default": "./dist/spec/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nomicfoundation/ignition-core": "0.15.15",
    "viem": "^2.54.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
