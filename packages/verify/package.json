{
  "name": "@redeploy/verify",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Verification: source/bytecode verification (Etherscan/Sourcify) and on-chain assertion that live configuration matches the declared spec.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@redeploy/config": "workspace:*",
    "@redeploy/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
