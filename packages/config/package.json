{
  "name": "@redeploy/config",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Post-deployment configuration: declarative config steps, resumable partial configuration, config-state idempotency.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./steps": {
      "types": "./dist/steps/index.d.ts",
      "default": "./dist/steps/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@redeploy/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "viem": "^2.54.1"
  }
}
