{
  "name": "@redeploy/deploy-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "HTTP deploy server: exposes deployment simulation and execution as an API. Built on node:http, no framework deps.",
  "scripts": {
    "dev": "node --watch dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@redeploy/config": "workspace:*",
    "@redeploy/core": "workspace:*",
    "@redeploy/reader": "workspace:*",
    "@redeploy/verify": "workspace:*",
    "viem": "^2.54.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
