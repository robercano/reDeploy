# Copy to .env (gitignored) and fill in. Never commit real secrets.

# RPC endpoints
RPC_URL_SEPOLIA=
RPC_URL_MAINNET=

# Local / Anvil deploy (deploy-server)
# Local deploy-server (real deploy path). Anvil listens here by default.
RPC_URL=http://127.0.0.1:8545
# Foundry build artifacts dir the deploy-server resolves contracts from.
# Defaults to <repo>/contracts/out when unset.
FOUNDRY_OUT=

# Deployer key. Used for REAL deploys via deploy-server's POST /api/deploy.
# Use a throwaway/test key (e.g. an Anvil dev key) locally; prefer a keystore
# or hardware wallet for real deploys. NEVER commit a real secret key here.
# May be provided with or without a leading "0x" prefix -- deploy-server normalizes it.
DEPLOYER_PRIVATE_KEY=

# Optional deploy-server overrides (uncomment to use):
# DEPLOYMENT_DIR=       # where the Ignition journal is persisted (default: OS-temp dir)
# PORT=8787             # deploy-server HTTP port
# HOST=127.0.0.1        # deploy-server bind address (loopback by default)

# Verification (deploy-server's POST /api/verify/source -- SERVER-SIDE ONLY,
# never sent to or read from the browser/studio).
# Etherscan (or Etherscan-compatible) API key. When unset, source
# verification is skipped cleanly (reported as skipped:true, never an error).
ETHERSCAN_API_KEY=
# Optional: override the Etherscan-compatible API base URL for a non-mainnet
# network or a self-hosted/compatible explorer (e.g. an L2's Etherscan-style
# API). Defaults to https://api.etherscan.io/api when unset.
# ETHERSCAN_API_URL=

# GitHub bot machine account — classic PAT with `repo` scope. Used ONLY to
# create PRs (via .claude/scripts/bot-gh.sh) so the PR author is the bot and
# the repo owner can formally approve. The bot must be a collaborator on this
# repo. One generically-named bot (e.g. <you>-assistant-bot) is reusable
# across all your repos. Setup checklist: docs/USAGE.md § One-time setup.
GH_BOT_TOKEN=
