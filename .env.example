# Copy to .env (gitignored) and fill in. Never commit real secrets.

# RPC endpoints
RPC_URL_SEPOLIA=
RPC_URL_MAINNET=

# Deployer key (use a throwaway/test key; prefer a keystore or hardware wallet for real deploys)
DEPLOYER_PRIVATE_KEY=

# Verification
ETHERSCAN_API_KEY=

# GitHub machine account ("redeploy bot") — classic PAT with `repo` scope.
# Used ONLY to create PRs (via .claude/scripts/bot-gh.sh) so the PR author is
# the bot and the repo owner can formally approve. The bot account must be a
# collaborator on this repo.
REDEPLOY_BOT_TOKEN=
